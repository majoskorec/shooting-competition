{% extends 'base.html.twig' %}

{% block title %}Súťaže LM{% endblock %}

{% block body %}
    <twig:Menu />
    <div class="container-xxl">
        <h1 class="h2 mt-4 mb-3">
            Súťaže LM
        </h1>
        <div class="row mb-3">
            <div class="col-12">
                <div class="list-group">
                    {% for competition in competitions %}
                        <a
                            href="{{ path(constant('App\\Controller\\Public\\PresentationController::ROUTE_NAME'), {
                                id: competition.id,
                            }) }}"
                            class="list-group-item list-group-item-action d-flex justify-content-between align-items-center fs-4 py-3"
                        >
                            {{ competition.name }}
                            -
                            {{ competition.competitionStart|date('d.m.Y') }}
                            <span class="badge {{ competition.status.backgroundColor }}">
                                {{ competition.status|trans }}
                            </span>
                        </a>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
