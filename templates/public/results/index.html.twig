{% extends 'base.html.twig' %}

{% block title %}Výsledky{% endblock %}

{% block body %}
<div class="container">
    <h1 class="h2 mt-4 mb-3">
        Výsledky - {{ results.competition.name }} - {{ results.category.title }} - {{ results.competition.competitionStart|date('d.m.Y') }}
    </h1>

    <div class="bg-white rounded-4 p-2 mb-3">
        <ul class="nav nav-pills">
            {% for category in categories.categories %}
                <li class="nav-item">
                    <a
                        {% if results.category.slug === category.slug %}
                            class="nav-link active"
                            aria-current="page"
                            href="#"
                        {% else %}
                            class="nav-link"
                            href="{{ path(constant('App\\Controller\\Public\\ResultsController::ROUTE_NAME'), {
                                id: results.competition.id,
                                categorySlug: category.slug,
                            }) }}"
                        {% endif %}
                    >
                        {{ category.title }}
                    </a>
                </li>
            {% endfor %}
        </ul>
    </div>

    <div class="border rounded-4 p-3 bg-white table-responsive mb-3">
        <table
            class="table table-striped table-hover table-sm"
            style="white-space: nowrap;"
        >
            <thead>
            <tr>
                {% if results.category.categoryType == enum('App\\Competition\\Results\\Model\\CategoryType').Teams %}
                    {% include 'public/results/_team_headers.html.twig' %}
                {% else %}
                    {% include 'public/results/_individual_headers.html.twig' %}
                {% endif %}
            </tr>
            </thead>
            <tbody>
            {% for competitors_results_with_rank in results.competitorsResultsWithRank %}
                {# @var competitors_results_with_rank \App\Competition\Results\Model\CompetitorResultWithRank #}
                {% if results.category.categoryType == enum('App\\Competition\\Results\\Model\\CategoryType').Teams %}
                    {% include 'public/results/_team_data.html.twig' %}
                {% else %}
                    {% include 'public/results/_individual_data.html.twig' %}
                {% endif %}
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
