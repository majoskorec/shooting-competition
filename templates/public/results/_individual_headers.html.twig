{% if not results.category.sortByRank %}
    <th
        class="text-center fs-75"
        scope="col"
    >
        Štartovné<br />
        číslo
    </th>
{% else %}
    <th
        scope="col"
        class="text-center"
    >
        #
    </th>
{% endif %}
<th scope="col">
    Meno
</th>
{% for target in results.competition.targetConfigurationSnapshotOrdered %}
    <th scope="col" class="text-end">
        {{ targetShortName(target.name) }}
    </th>
{% endfor %}
<th scope="col" class="text-end">
    Spolu
</th>
{% if not results.category.sortByRank %}
    <th scope="col" class="text-center">
        Poradie
    </th>
{% endif %}
