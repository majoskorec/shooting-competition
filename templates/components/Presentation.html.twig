{% form_theme form 'bootstrap_5_layout.html.twig' %}

<div {{ attributes.defaults(stimulus_controller('presentation-form')) }}>
    {{ form_start(form, {
        attr: {
            'data-action': 'live#action:prevent',
            'data-live-action-param': 'save',
            'data-model': 'debounce(100)|*',
        }
    }) }}
    <div class="row">
        <div class="col-6">
            {{ form_row(form.lastName) }}
            {{ form_row(form.firstName) }}
        </div>
        <div class="col-6">
            {{ form_row(form.shooter) }}
        </div>
    </div>
    <div class="row">
        <div class="col-6">
            {{ form_row(form.club, {
                'attr': {
                    'data-presentation-form-target': 'club',
                }
            }) }}
            {{ form_row(form.email) }}
            {{ form_row(form.sharedWeaponCode) }}
        </div>
        <div class="col-6">
            {{ form_row(form.categories) }}
        </div>
    </div>
    <hr />
    <div class="row">
        {% if this.competition.teamMemberCount > 1 %}
            <div class="col-6">
                {{ form_row(form.teamName, {
                    'attr': {
                        'data-presentation-form-target': 'teamName',
                    }
                }) }}
                <button
                    {{ stimulus_action('presentation-form', 'setTeamFromClub') }}
                    class="btn btn-secondary"
                >
                    Použi Klub / PZ
                </button>
            </div>
            <div class="col-6">
                {{ form_row(form.competitionTeam) }}
            </div>

    {% else %}
        <div class="col-12 text-center">
            Bez Družstiev
        </div>
    {% endif %}
    </div>

    {{ form_errors(form) }}

    <button class="btn btn-primary">
        Ulož
    </button>
    {{ form_end(form) }}
</div>
