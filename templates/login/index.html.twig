{% extends 'base.html.twig' %}

{% block title %}Prihlásenie | Admin{% endblock %}

{% block body %}
    <twig:Menu />
    <div class="container-xxl py-5">
        <div class="row">
            <div class="offset-lg-4 col-lg-4 offset-md-2 col-md-8">
                <h1 class="h3 mb-4">
                    Admin prihlásenie
                </h1>

                {% if error %}
                    <div class="alert alert-danger" role="alert">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post">
                    <div class="mb-3">
                        <label
                            for="username"
                            class="form-label"
                        >
                            E-mail
                        </label>
                        <input
                            type="email"
                            value="{{ last_username }}"
                            name="_username"
                            id="username"
                            class="form-control"
                            autocomplete="email"
                            required
                            autofocus
                        >
                    </div>

                    <div class="mb-3">
                        <label
                            for="password"
                            class="form-label"
                        >
                            Heslo
                        </label>
                        <input
                            type="password"
                            name="_password"
                            id="password"
                            class="form-control"
                            autocomplete="current-password"
                            required
                        >
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button class="btn btn-primary w-100" type="submit">Prihlásiť sa</button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
