{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}
    {% include 'admin/competition/_competition_content_title.html.twig' with {
        title: 'Prezentácia:',
        competition: competition,
    } %}
{% endblock %}

{% block main %}
    <div>
        <a
            href="{{ path(constant('App\\Controller\\Admin\\Competition\\DrawController::ROUTE_NAME'), {
                entityId: competition.id,
            }) }}"
            class="btn btn-warning"
        >
            Rozlosovanie
        </a>
        <a
            href="{{ path('admin_dashboard_competition_edit', {
                entityId: competition.id,
            }) }}"
            class="btn btn-primary"
        >
            Úprava
        </a>
    </div>

    <hr />
    <div>
        <twig:Presentation
            competition="{{ competition }}"
        />
    </div>

    <hr />

    <table class="table table-striped table-hover">
        <thead>
        <tr class="text-nowrap align-middle">
            <th
                scope="col"
                class="text-center fs-75"
            >
                Štartovné
                <br />
                číslo
            </th>
            <th scope="col">
                Strelec
            </th>
            <th scope="col">
                Klub / PZ
            </th>
            <th scope="col">
                Družstvo
            </th>
            <th
                scope="col"
                class="text-center"
            >
                Spoločná
                <br />
                zbraň
            </th>
            {% for category in competition.categories %}
                <th
                    scope="col"
                    class="text-center"
                >
                    {{ category.name }}
                </th>
            {% endfor %}
            <th>
                Stav
            </th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        {% for competitor in competitors %}
            <tr class="align-middle">
                <th
                    scope="row"
                    class="text-center min-width"
                >
                    {{ competitor.startNumber }}
                </th>
                <td>
                    {{ competitor.shooter.fullName }}
                </td>
                <td>
                    {{ competitor.shooter.club }}
                </td>
                <td>
                    {{ competitor.competitionTeam is not null ? competitor.competitionTeam.name }}
                </td>
                <td class="text-center min-width">
                    {{ competitor.sharedWeaponCode }}
                </td>
                {% for category in competition.categories %}
                    <td class="text-center min-width">
                        {{ competitor.categories.contains(category) ? ux_icon('bi:check-circle-fill', { class: 'text-success', style: 'height: 1em;' }) }}
                    </td>
                {% endfor %}
                <td>{{ competitor.status|trans }}</td>
                <td class="text-nowrap min-width">
                    <a
                        href="{{ path('admin_dashboard_competitor_edit', {entityId: competitor.id}) }}"
                        class="btn btn-warning"
                    >
                        Upraviť
                    </a>
                    <a
                        class="btn btn-danger btn-invisible action-delete"
                        href="{{ path('admin_dashboard_competitor_delete', {
                            entityId: competitor.id,
                            presentation: '1',
                        }) }}"
                        role="button"
                        data-action-name="delete"
                        formaction="{{ path('admin_dashboard_competitor_delete', {
                            entityId: competitor.id,
                            presentation: '1',
                        }) }}"
                        data-bs-toggle="modal"
                        data-bs-target="#modal-action-confirmation"
                        data-action-confirmation="true"
                        data-action-variant="danger"
                        data-action-entity-name="Súťažiaci"
                        data-action-entity-id="{{ competitor.id }}"
                    >
                        <span class="icon btn-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" fill="currentColor">
                                <!--! Font Awesome Free 6.6.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) Copyright 2024 Fonticons, Inc. -->
                                <path d="M170.5 51.6L151.5 80l145 0-19-28.4c-1.5-2.2-4-3.6-6.7-3.6l-93.7 0c-2.7 0-5.2 1.3-6.7 3.6zm147-26.6L354.2 80 368 80l48 0 8 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-8 0 0 304c0 44.2-35.8 80-80 80l-224 0c-44.2 0-80-35.8-80-80l0-304-8 0c-13.3 0-24-10.7-24-24S10.7 80 24 80l8 0 48 0 13.8 0 36.7-55.1C140.9 9.4 158.4 0 177.1 0l93.7 0c18.7 0 36.2 9.4 46.6 24.9zM80 128l0 304c0 17.7 14.3 32 32 32l224 0c17.7 0 32-14.3 32-32l0-304L80 128zm80 64l0 208c0 8.8-7.2 16-16 16s-16-7.2-16-16l0-208c0-8.8 7.2-16 16-16s16 7.2 16 16zm80 0l0 208c0 8.8-7.2 16-16 16s-16-7.2-16-16l0-208c0-8.8 7.2-16 16-16s16 7.2 16 16zm80 0l0 208c0 8.8-7.2 16-16 16s-16-7.2-16-16l0-208c0-8.8 7.2-16 16-16s16 7.2 16 16z">
                                </path>
                            </svg>
                        </span>
                        <span class="btn-label">
                            <span class="action-label">
                                Zmazať
                            </span>
                        </span>
                    </a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    {{ include('@EasyAdmin/crud/includes/_action_confirmation_modal.html.twig', with_context: false) }}
{% endblock %}
