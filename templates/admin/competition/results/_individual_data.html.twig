{# @var competitors_results_with_rank \App\Competition\Results\Model\CompetitorResultWithRank #}
<tr>
    <th
        scope="row"
        class="text-center min-width"
    >
        {{ competitors_results_with_rank.rank|rankIcon }}
    </th>
    <td>
        {{ competitors_results_with_rank.competitorResult.name }}
    </td>
    {% include 'admin/competition/results/_competitor_result_data.html.twig' with {
        competitor_sub_results: competitors_results_with_rank.competitorResult.competitorSubResults[0],
        results: results,
    } %}
    <td class="text-end min-width">
        {{ competitors_results_with_rank.competitorResult.finalResult }}
    </td>
</tr>
