{% extends 'base.html.twig' %}

{% block title %}Admin{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-1">Admin rozhranie</h1>
                <p class="text-body-secondary mb-0">Prihlásený používateľ: {{ app.user.fullName }}</p>
            </div>

            <a href="{{ path('app_logout') }}" class="btn btn-outline-secondary">Odhlásiť sa</a>
        </div>

        <div class="alert alert-success mb-0" role="alert">
            Prihlásenie cez Symfony Security je aktívne.
        </div>
    </div>
{% endblock %}
